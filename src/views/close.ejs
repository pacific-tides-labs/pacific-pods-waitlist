<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PacificPods | Waitlist</title>
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@PacificPods">
  <meta name="twitter:title" content="🐬 PacificPods Waitlist">
  <meta name="twitter:image" content="https://pacificpods.xyz/static/logo.jpeg">
  <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="style.css">
  <link rel="icon" type="image/jpeg" href="./static/logo.jpeg">
</head>
<body>
  <% if(valid){ %>
    <div id="scoreboard">
      Score: <span id="score">0</span>
    </div>
    
      <div id="ocean-bg"></div>

     <div class="container" id="main-container">
    <header>
      <h1>🐬 PacificPods</h1>
      <p>Dolphins Coming to Pacifica</p>
    </header>

    <div class="card" id="step-5">
      <h2>🎉 You're in the Pod! 🎉</h2>
      <p class="subtitle">Keep your sunglasses ready. <br> We'll notify you when the wave hits.</p>

      <div id="tab-pass" class="tab-content">
        <div class="pass-details">
          <p><strong>Email:</strong> <br><span id="disp-email"><%= email%></span></p>
          <p><strong>Wallet:</strong> <br><span id="disp-wallet"><%= walletAddress%></span></p>
          <p>
            <strong>Referral:</strong> <br>
            <span style="display: flex; align-items: center; gap: 10px; margin-top: 5px;">
              <span id="disp-referral"><%= referral%></span>
              <button id="copy-btn" class="copy-btn" onclick="copyReferral()">📋 Copy</button>
            </span>
          </p>
          <p><strong>Tweet:</strong> <br><span id="disp-tweet"><%= xUsername%></span></p>
          <p><strong>Referral Score:</strong> <br><span id="disp-score" style="color: #ff9f1c; font-weight: 700; font-size: 1.4rem;"><%= score%></span></p>
        </div>
        <button class="social-share-btn" onclick="shareToX()">🐦 Share to X</button>
      </div>
    </div>
  </div>

  <% } else { %>
  <div id="scoreboard">
    Score: <span id="score">0</span>
  </div>

  <div id="ocean-bg"></div>

  <div class="container" id="main-container">
    <header>
      <h1>🐬 PacificPods</h1>
      <p>Dolphins Coming to Pacifica</p>
    </header>

    <div id="flow-register">
      <div class="card" id="step-0">
        <h2>Waitlist Closed.</h2>
        <p class="subtitle">We deeply appreciate the tremendous support we’ve received. Due to an unprecedented volume of signups, we have paused new waitlist applications to ensure a quality experience for our current members.<br>Thank you for your understanding.</p>
        
        <button onclick="window.open('https://x.com/PacificPod98082', '_blank')">Stay Tuned on Twitter!</button>      </div>
    </div>

    <div id="flow-login" class="hidden">
      <div class="card">
        <h2>Welcome Back! 🌊</h2>
        <p class="subtitle">Enter your wallet address to check your pod status.</p>
        <div class="input-group">
          <input type="text" id="login-wallet" placeholder="0x... ">
        </div>
        <button id="login-btn" onclick="processLogin()">Access Pass 🔑</button>
        <p class="error" id="error-login">Wallet not found. Please register first.</p>
      </div>
    </div>

    <div class="auth-tabs" id="auth-tabs">
        <button class="auth-tab active" id="tab-reg" onclick="switchAuth('register')">Register</button>
        <button class="auth-tab" id="tab-log" onclick="switchAuth('login')">Login</button>
    </div>

  <% } %>

  <script>
    // const loggedInUser = <%- typeof user !== 'undefined' ? JSON.stringify(user) : 'null' %>;
  </script>
  <script src="script.js"></script>
</body>
</html>